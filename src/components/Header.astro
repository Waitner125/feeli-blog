---
import { siteConfig } from "@/lib/types";
import ThemeToggle from "./ThemeToggle.astro";

const currentPath = Astro.url.pathname;
---

<header class="site-header">
	<nav class="site-nav" transition:persist>
		<div class="site-nav-shell">
			<a href="/" class="site-brand" aria-label={siteConfig.name}>
				<span class="site-brand-mark">E</span>
				<span class="site-brand-copy">
					<strong>{siteConfig.name}</strong>
					<small>流畅、克制、持续更新的技术写作</small>
				</span>
			</a>
			<ul class="nav-links">
				<li>
					<a href="/" class:list={["nav-link", { active: currentPath === "/" }]}>首页</a>
				</li>
				<li>
					<a href="/blog" class:list={["nav-link", { active: currentPath.startsWith("/blog") }]}>归档</a>
				</li>
				<li>
					<a href="/search" class:list={["nav-link", { active: currentPath === "/search" }]}>搜索</a>
				</li>
			</ul>
			<div class="nav-actions">
				<ThemeToggle />
			</div>
		</div>
	</nav>
</header>

<style>
	.site-header {
		position: sticky;
		top: 0;
		z-index: 30;
		padding-inline: 0;
		pointer-events: none;
		transition:
			top var(--nav-motion-main),
			padding-inline var(--nav-motion-main);
	}

	.site-nav {
		position: relative;
		width: 100%;
		pointer-events: none;
		isolation: isolate;
		contain: paint;
	}

	.site-nav::before {
		content: "";
		position: absolute;
		inset: 0;
		border-top: none;
		border-left: none;
		border-right: none;
		border-bottom: 1px solid rgba(255, 255, 255, 0.14);
		border-radius: 0;
		background: var(--nav-shell-open-surface);
		box-shadow: var(--nav-shell-open-shadow);
		backdrop-filter: blur(14px) saturate(125%);
		-webkit-backdrop-filter: blur(14px) saturate(125%);
		transform-origin: top center;
		transform: translate3d(0, 0, 0);
		backface-visibility: hidden;
		will-change: inset, border-radius, transform, box-shadow;
		transition:
			inset var(--nav-motion-main),
			border-radius var(--nav-motion-main),
			background-color var(--nav-motion-surface),
			border-color var(--nav-motion-surface),
			box-shadow var(--nav-motion-surface),
			transform var(--nav-motion-transform);
	}

	.site-nav-shell {
		position: relative;
		z-index: 1;
		display: grid;
		grid-template-columns: minmax(0, 1fr) auto minmax(0, 1fr);
		align-items: center;
		gap: var(--space-md);
		width: min(100%, var(--nav-shell-max-width));
		margin-inline: auto;
		padding:
			0.88rem
			calc(1.18rem + env(safe-area-inset-right))
			0.96rem
			calc(1.18rem + env(safe-area-inset-left));
		pointer-events: auto;
	}

	.site-brand {
		display: inline-flex;
		align-items: center;
		gap: 0.85rem;
		min-width: 0;
		justify-self: start;
	}

	.site-brand-mark {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 2.8rem;
		height: 2.8rem;
		border-radius: var(--radius-inner);
		background: #0a84ff;
		color: #ffffff;
		font-size: 1rem;
		font-weight: 700;
		letter-spacing: 0.08em;
		box-shadow: 0 12px 30px -24px rgba(10, 132, 255, 0.4);
	}

	.site-brand-copy {
		display: grid;
		gap: 0.18rem;
		min-width: 0;
	}

	.site-brand-copy strong {
		font-size: 1rem;
		font-weight: 700;
		color: var(--color-text);
		letter-spacing: -0.02em;
	}

	.site-brand-copy small {
		color: var(--color-text-muted);
		font-size: 0.78rem;
		white-space: nowrap;
		transform-origin: left center;
		transition:
			opacity var(--nav-motion-surface),
			transform var(--nav-motion-main);
	}

	.nav-links,
	.nav-actions {
		display: inline-flex;
		align-items: center;
		gap: var(--space-md);
		list-style: none;
	}

	.nav-links {
		justify-self: center;
	}

	.nav-actions {
		justify-self: end;
		min-width: max-content;
	}

	.nav-link {
		color: var(--color-text-secondary);
		font-size: 0.92rem;
		padding: 0.72rem 1rem;
		border-radius: var(--radius-pill);
		border: 1px solid transparent;
		background: transparent;
		transition:
			color var(--transition),
			background-color var(--transition),
			border-color var(--transition),
			transform var(--transition);
	}

	.nav-link:hover,
	.nav-link.active {
		color: var(--color-accent);
		background: rgba(10, 132, 255, 0.08);
		border-color: rgba(10, 132, 255, 0.12);
	}

	.nav-link:hover,
	.nav-link.active {
		transform: translateY(-1px);
	}

	:global(html[data-nav-condensed]) .site-header {
		top: 0.75rem;
		padding-inline: 0.8rem;
	}

	:global(html[data-nav-condensed]) .site-nav::before {
		inset-inline: max(
			var(--nav-shell-condensed-inset-desktop),
			calc((100% - var(--nav-shell-max-width)) / 2)
		);
		border: 1px solid rgba(255, 255, 255, 0.18);
		border-radius: var(--nav-shell-condensed-radius);
		background: var(--nav-shell-condensed-surface);
		box-shadow: var(--nav-shell-condensed-shadow);
		transform: translate3d(0, 0, 0) scale(var(--nav-shell-condensed-scale));
	}

	:global(html[data-nav-condensed]) .site-brand-copy small {
		opacity: 0.68;
		transform: translateY(-1px);
	}

	@media (max-width: 960px) {
		.site-header {
			top: 0;
			padding-inline: 0;
		}

		.site-nav {
			width: 100%;
		}

		.site-nav-shell {
			display: flex;
			flex-wrap: wrap;
			justify-content: center;
			width: 100%;
			padding:
				0.82rem
				calc(0.9rem + env(safe-area-inset-right))
				0.95rem
				calc(0.9rem + env(safe-area-inset-left));
		}

		.site-brand {
			width: 100%;
			justify-content: center;
		}

		.site-brand-copy {
			justify-items: center;
		}

		.site-brand-copy small {
			white-space: normal;
			text-align: center;
		}

		.nav-links {
			order: 2;
			justify-content: center;
			flex-wrap: wrap;
		}

		.nav-actions {
			order: 3;
		}

		:global(html[data-nav-condensed]) .site-header {
			top: 0.5rem;
			padding-inline: 0.5rem;
		}

		:global(html[data-nav-condensed]) .site-nav::before {
			inset-inline: var(--nav-shell-condensed-inset-mobile);
			border-radius: 28px;
			transform: none;
		}
	}

	@media (max-width: 640px) {
		.site-nav-shell {
			padding: 0.8rem;
		}

		.nav-links,
		.nav-actions {
			width: 100%;
			justify-content: center;
			flex-wrap: wrap;
			gap: 0.5rem;
		}

		.nav-link {
			padding-inline: 0.88rem;
		}

		:global(html[data-nav-condensed]) .site-nav::before {
			border-radius: 24px;
		}
	}
</style>
