---
import { siteConfig } from "@/lib/types";
import ThemeToggle from "./ThemeToggle.astro";

const currentPath = Astro.url.pathname;
---

<header class="site-header">
	<nav class="container site-nav glass-panel" transition:persist>
		<a href="/" class="site-brand" aria-label={siteConfig.name}>
			<span class="site-brand-mark">E</span>
			<span class="site-brand-copy">
				<strong>{siteConfig.name}</strong>
				<small>流畅、克制、持续更新的技术写作</small>
			</span>
		</a>
		<ul class="nav-links">
			<li>
				<a href="/" class:list={["nav-link", { active: currentPath === "/" }]}>首页</a>
			</li>
			<li>
				<a href="/blog" class:list={["nav-link", { active: currentPath.startsWith("/blog") }]}>归档</a>
			</li>
			<li>
				<a href="/search" class:list={["nav-link", { active: currentPath === "/search" }]}>搜索</a>
			</li>
		</ul>
		<div class="nav-actions">
			<ThemeToggle />
		</div>
	</nav>
</header>

<style>
	.site-header {
		position: sticky;
		top: 0;
		z-index: 30;
		padding-inline: 0;
		pointer-events: none;
		transition:
			top 320ms cubic-bezier(0.2, 0.8, 0.2, 1),
			padding-inline 320ms cubic-bezier(0.2, 0.8, 0.2, 1);
	}

	.site-nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: var(--space-md);
		width: min(100%, calc(var(--max-width) + 4rem));
		padding: 0.9rem 1.4rem 1rem;
		border-top: none;
		border-radius: 0 0 30px 30px;
		background: rgba(255, 255, 255, 0.16);
		box-shadow: 0 12px 28px -24px rgba(8, 18, 34, 0.16);
		pointer-events: auto;
		transform-origin: top center;
		transition:
			width 320ms cubic-bezier(0.2, 0.8, 0.2, 1),
			padding 320ms cubic-bezier(0.2, 0.8, 0.2, 1),
			border-radius 320ms cubic-bezier(0.2, 0.8, 0.2, 1),
			background-color 320ms cubic-bezier(0.2, 0.8, 0.2, 1),
			border-color 320ms cubic-bezier(0.2, 0.8, 0.2, 1),
			box-shadow 320ms cubic-bezier(0.2, 0.8, 0.2, 1),
			backdrop-filter 320ms cubic-bezier(0.2, 0.8, 0.2, 1),
			-webkit-backdrop-filter 320ms cubic-bezier(0.2, 0.8, 0.2, 1);
	}

	.site-brand {
		display: inline-flex;
		align-items: center;
		gap: 0.85rem;
		min-width: 0;
	}

	.site-brand-mark {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 2.8rem;
		height: 2.8rem;
		border-radius: var(--radius-inner);
		background: #0a84ff;
		color: #ffffff;
		font-size: 1rem;
		font-weight: 700;
		letter-spacing: 0.08em;
		box-shadow: 0 12px 30px -24px rgba(10, 132, 255, 0.4);
	}

	.site-brand-copy {
		display: grid;
		gap: 0.18rem;
		min-width: 0;
	}

	.site-brand-copy strong {
		font-size: 1rem;
		font-weight: 700;
		color: var(--color-text);
		letter-spacing: -0.02em;
	}

	.site-brand-copy small {
		color: var(--color-text-muted);
		font-size: 0.78rem;
		white-space: nowrap;
	}

	.nav-links,
	.nav-actions {
		display: inline-flex;
		align-items: center;
		gap: var(--space-md);
		list-style: none;
	}

	.nav-link {
		color: var(--color-text-secondary);
		font-size: 0.92rem;
		padding: 0.72rem 1rem;
		border-radius: var(--radius-pill);
		border: 1px solid transparent;
		background: transparent;
		transition:
			color var(--transition),
			background-color var(--transition),
			border-color var(--transition),
			transform var(--transition);
	}

	.nav-link:hover,
	.nav-link.active {
		color: var(--color-accent);
		background: rgba(10, 132, 255, 0.08);
		border-color: rgba(10, 132, 255, 0.12);
	}

	.nav-link:hover,
	.nav-link.active {
		transform: translateY(-1px);
	}

	:global(html[data-nav-condensed]) .site-header {
		top: 0.85rem;
		padding-inline: 0.5rem;
	}

	:global(html[data-nav-condensed]) .site-nav {
		width: min(calc(100% - 1rem), var(--max-width));
		padding: 0.72rem 0.92rem;
		border-top: 1px solid rgba(255, 255, 255, 0.18);
		border-radius: var(--radius-panel);
		background: rgba(255, 255, 255, 0.12);
		box-shadow: 0 18px 36px -30px rgba(8, 18, 34, 0.22);
		backdrop-filter: blur(16px) saturate(130%);
		-webkit-backdrop-filter: blur(16px) saturate(130%);
	}

	@media (max-width: 960px) {
		.site-header {
			top: 0;
			padding-inline: 0;
		}

		.site-nav {
			flex-wrap: wrap;
			justify-content: center;
			width: 100%;
			padding: 0.82rem 0.9rem 0.95rem;
			border-radius: 32px;
		}

		.site-brand {
			width: 100%;
			justify-content: center;
		}

		.site-brand-copy {
			justify-items: center;
		}

		.site-brand-copy small {
			white-space: normal;
			text-align: center;
		}

		.nav-links {
			order: 2;
			justify-content: center;
			flex-wrap: wrap;
		}

		.nav-actions {
			order: 3;
		}

		:global(html[data-nav-condensed]) .site-header {
			top: 0.5rem;
			padding-inline: 0.5rem;
		}

		:global(html[data-nav-condensed]) .site-nav {
			width: min(calc(100% - 1rem), var(--max-width));
			padding: 0.78rem 0.88rem;
			border-radius: 28px;
		}
	}

	@media (max-width: 640px) {
		.site-nav {
			padding: 0.8rem;
			border-radius: 0 0 24px 24px;
		}

		.nav-links,
		.nav-actions {
			width: 100%;
			justify-content: center;
			flex-wrap: wrap;
			gap: 0.5rem;
		}

		.nav-link {
			padding-inline: 0.88rem;
		}

		:global(html[data-nav-condensed]) .site-nav {
			border-radius: 24px;
		}
	}
</style>
