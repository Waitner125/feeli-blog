---
import { siteConfig } from "@/lib/types";
import ThemeToggle from "./ThemeToggle.astro";

const currentPath = Astro.url.pathname;
---

<header class="site-header">
	<nav class="site-nav glass-panel" transition:persist>
		<a href="/" class="site-brand" aria-label={siteConfig.name}>
			<span class="site-brand-mark">E</span>
			<span class="site-brand-copy">
				<strong>{siteConfig.name}</strong>
				<small>流畅、克制、持续更新的技术写作</small>
			</span>
		</a>
		<ul class="nav-links">
			<li>
				<a href="/" class:list={["nav-link", { active: currentPath === "/" }]}>首页</a>
			</li>
			<li>
				<a href="/blog" class:list={["nav-link", { active: currentPath.startsWith("/blog") }]}>归档</a>
			</li>
			<li>
				<a href="/search" class:list={["nav-link", { active: currentPath === "/search" }]}>搜索</a>
			</li>
		</ul>
		<div class="nav-actions">
			<ThemeToggle />
		</div>
	</nav>
</header>

<style>
	.site-header {
		--nav-motion-main: 520ms cubic-bezier(0.22, 1, 0.36, 1);
		--nav-motion-surface: 420ms cubic-bezier(0.33, 1, 0.68, 1);
		--nav-motion-transform: 560ms cubic-bezier(0.16, 1, 0.3, 1);
		position: sticky;
		top: 0;
		z-index: 30;
		padding-inline: 0;
		pointer-events: none;
		transition:
			top var(--nav-motion-main),
			padding-inline var(--nav-motion-main);
	}

	.site-nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: var(--space-md);
		width: 100vw;
		max-width: none;
		margin-inline: calc(50% - 50vw);
		padding:
			0.9rem
			calc(1.4rem + env(safe-area-inset-right))
			1rem
			calc(1.4rem + env(safe-area-inset-left));
		border-top: none;
		border-left: none;
		border-right: none;
		border-bottom: 1px solid rgba(255, 255, 255, 0.14);
		border-radius: 0;
		background: rgba(255, 255, 255, 0.16);
		box-shadow: 0 10px 24px -26px rgba(8, 18, 34, 0.18);
		pointer-events: auto;
		transform-origin: top center;
		transform: translate3d(0, 0, 0);
		backface-visibility: hidden;
		will-change:
			width,
			max-width,
			margin,
			padding,
			border-radius,
			transform,
			box-shadow;
		transition:
			width var(--nav-motion-main),
			max-width var(--nav-motion-main),
			margin var(--nav-motion-main),
			padding var(--nav-motion-main),
			border-radius var(--nav-motion-main),
			background-color var(--nav-motion-surface),
			border-color var(--nav-motion-surface),
			box-shadow var(--nav-motion-surface),
			backdrop-filter var(--nav-motion-surface),
			-webkit-backdrop-filter var(--nav-motion-surface),
			transform var(--nav-motion-transform);
	}

	.site-brand {
		display: inline-flex;
		align-items: center;
		gap: 0.85rem;
		min-width: 0;
	}

	.site-brand-mark {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 2.8rem;
		height: 2.8rem;
		border-radius: var(--radius-inner);
		background: #0a84ff;
		color: #ffffff;
		font-size: 1rem;
		font-weight: 700;
		letter-spacing: 0.08em;
		box-shadow: 0 12px 30px -24px rgba(10, 132, 255, 0.4);
	}

	.site-brand-copy {
		display: grid;
		gap: 0.18rem;
		min-width: 0;
	}

	.site-brand-copy strong {
		font-size: 1rem;
		font-weight: 700;
		color: var(--color-text);
		letter-spacing: -0.02em;
	}

	.site-brand-copy small {
		color: var(--color-text-muted);
		font-size: 0.78rem;
		white-space: nowrap;
		transform-origin: left center;
		transition:
			opacity var(--nav-motion-surface),
			transform var(--nav-motion-main);
	}

	.nav-links,
	.nav-actions {
		display: inline-flex;
		align-items: center;
		gap: var(--space-md);
		list-style: none;
	}

	.nav-link {
		color: var(--color-text-secondary);
		font-size: 0.92rem;
		padding: 0.72rem 1rem;
		border-radius: var(--radius-pill);
		border: 1px solid transparent;
		background: transparent;
		transition:
			color var(--transition),
			background-color var(--transition),
			border-color var(--transition),
			transform var(--transition);
	}

	.nav-link:hover,
	.nav-link.active {
		color: var(--color-accent);
		background: rgba(10, 132, 255, 0.08);
		border-color: rgba(10, 132, 255, 0.12);
	}

	.nav-link:hover,
	.nav-link.active {
		transform: translateY(-1px);
	}

	:global(html[data-nav-condensed]) .site-header {
		top: 0.75rem;
		padding-inline: 0.8rem;
	}

	:global(html[data-nav-condensed]) .site-nav {
		width: min(calc(100% - 1.6rem), 1060px);
		max-width: 1060px;
		margin-inline: auto;
		padding: 0.72rem 1rem;
		border: 1px solid rgba(255, 255, 255, 0.18);
		border-radius: 999px;
		background: rgba(255, 255, 255, 0.12);
		box-shadow: 0 18px 38px -28px rgba(8, 18, 34, 0.24);
		backdrop-filter: blur(16px) saturate(130%);
		-webkit-backdrop-filter: blur(16px) saturate(130%);
		transform: translate3d(0, 0, 0) scale(0.992);
	}

	:global(html[data-nav-condensed]) .site-brand-copy small {
		opacity: 0.68;
		transform: translateY(-1px);
	}

	@media (max-width: 960px) {
		.site-header {
			top: 0;
			padding-inline: 0;
		}

		.site-nav {
			flex-wrap: wrap;
			justify-content: center;
			width: 100vw;
			max-width: none;
			margin-inline: calc(50% - 50vw);
			padding:
				0.82rem
				calc(0.9rem + env(safe-area-inset-right))
				0.95rem
				calc(0.9rem + env(safe-area-inset-left));
			border-radius: 0;
		}

		.site-brand {
			width: 100%;
			justify-content: center;
		}

		.site-brand-copy {
			justify-items: center;
		}

		.site-brand-copy small {
			white-space: normal;
			text-align: center;
		}

		.nav-links {
			order: 2;
			justify-content: center;
			flex-wrap: wrap;
		}

		.nav-actions {
			order: 3;
		}

		:global(html[data-nav-condensed]) .site-header {
			top: 0.5rem;
			padding-inline: 0.5rem;
		}

		:global(html[data-nav-condensed]) .site-nav {
			width: calc(100% - 1rem);
			max-width: none;
			padding: 0.78rem 0.88rem;
			border-radius: 28px;
			transform: none;
		}
	}

	@media (max-width: 640px) {
		.site-nav {
			padding: 0.8rem;
			border-radius: 0;
		}

		.nav-links,
		.nav-actions {
			width: 100%;
			justify-content: center;
			flex-wrap: wrap;
			gap: 0.5rem;
		}

		.nav-link {
			padding-inline: 0.88rem;
		}

		:global(html[data-nav-condensed]) .site-nav {
			border-radius: 24px;
			transform: none;
		}
	}
</style>
