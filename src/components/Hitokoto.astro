---
// src/components/Hitokoto.astro
export interface Props {
  fallback?: string;
}

// 从父组件接收的后备文案，如果未传入则使用默认句子
const { fallback = "✨ 言念君子，温其如玉。" } = Astro.props;
---

<div class="hitokoto-wrapper">
  <span id="hitokoto-text">{fallback}</span>
</div>

<script>
  // 该脚本只在客户端执行（因为组件使用了 client:load）
  const container = document.getElementById('hitokoto-text');
  if (container) {
    // 保存初始文本（后台配置的简介或默认值）
    const fallbackText = container.textContent || '';

    // 调用一言 API（v1.hitokoto.cn 支持 CORS）
    fetch('https://v1.hitokoto.cn')
      .then(response => response.json())
      .then(data => {
        if (data.hitokoto) {
          container.textContent = data.hitokoto;
        }
      })
      .catch(error => {
        console.warn('一言加载失败，保留默认文案:', error);
        container.textContent = fallbackText;
      });
  }
</script>

<style>
  .hitokoto-wrapper {
    display: inline; /* 保持与父容器内联，继承父级字体样式 */
  }

  #hitokoto-text {
    /* 完全继承父容器（.article-profile-bio）的字体、颜色、字号等 */
    font: inherit;
    color: inherit;
    transition: opacity 0.2s ease;
  }

  /* 可选：加载过程中微弱的占位效果（不影响布局） */
  #hitokoto-text:empty::before {
    content: "⋯";
    opacity: 0.5;
  }
</style>